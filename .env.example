# =============================================================================
# Obrio AI — Template de variáveis de ambiente
# =============================================================================
# Copie para .env.local ou .env e preencha os valores:
#   copy .env.example .env.local
#
# Projeto Supabase: kvofxprsmzyxssjpyfmy
# Dashboard API: https://supabase.com/dashboard/project/kvofxprsmzyxssjpyfmy/settings/api
# Dashboard DB:  https://supabase.com/dashboard/project/kvofxprsmzyxssjpyfmy/settings/database
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — API REST e Auth (obrigatórias para o app)
# -----------------------------------------------------------------------------

# URL da API do projeto.
# Onde obter: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://kvofxprsmzyxssjpyfmy.supabase.co

# Chave publishable (recomendada) — segura no browser com RLS ativo.
# Onde obter: Settings → API → Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Chave anon legacy (JWT) — fallback se publishable não estiver definida.
# Onde obter: Settings → API → anon / legacy API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Supabase — Server-side only (NUNCA usar NEXT_PUBLIC_)
# -----------------------------------------------------------------------------

# Secret key (recomendada) — bypass RLS; apenas server/scripts/admin.
# Onde obter: Settings → API → Secret key (sb_secret_...)
SUPABASE_SECRET_KEY=your-secret-key-here

# Service role legacy (JWT) — fallback para CLI e scripts antigos.
# Onde obter: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Supabase — Postgres direto (opcional, server/CLI only)
# -----------------------------------------------------------------------------

# Connection string do banco. Use %40 no lugar de @ na senha.
# Onde obter: Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.kvofxprsmzyxssjpyfmy.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# App — URLs públicas (opcional)
# -----------------------------------------------------------------------------

# URL base do app (redirects de auth, emails, links absolutos).
# Local: http://localhost:3000
# Produção: https://obrioai.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OpenNext / Cloudflare — desenvolvimento local (opcional)
# -----------------------------------------------------------------------------

# NEXTJS_ENV=development

# -----------------------------------------------------------------------------
# Cloudflare — CI/CD (secrets do GitHub, não commitar)
# -----------------------------------------------------------------------------

# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=3993b788758518b8ed046b055577f49d

# -----------------------------------------------------------------------------
# Integrações futuras (opcional)
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
